generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADVERTISER
  MEDIA_OWNER
  ADMIN
}

enum MediaType {
  BILLBOARD
  DIGITAL
  TRANSIT
  OTHER
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
  ANALYZING
  ANALYZED
  FAILED
}

enum MatchingStatus {
  SAVED
  INQUIRY
  NEGOTIATION
  CONTRACTING
  ACTIVE
  COMPLETED
  CANCELLED
}

// --- THINKKAD-style OOH Media (AI 업로드 → 검토 → 상세페이지) ---
enum MediaCategory {
  BILLBOARD
  DIGITAL_BOARD
  TRANSIT
  STREET_FURNITURE
  WALL
  ETC
}

enum MediaStatus {
  DRAFT
  /** 매체사 업로드 후 AI/관리자 검토 대기 */
  PENDING
  PUBLISHED
  /** 관리자 거부 */
  REJECTED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

/** 캠페인 종료 후 자동 발행 인보이스 */
enum CampaignInvoiceStatus {
  OPEN
  PAID
  VOID
}

enum InquiryStatus {
  PENDING
  REPLIED
  CLOSED
}

/** 문의 기반 매체 예약 계약 (조건 확정 → 서명 → PDF) */
enum InquiryContractStatus {
  DRAFT
  AWAITING_MEDIA_OWNER
  COMPLETED
}

enum CurrencyCode {
  KRW
  USD
  EUR
  JPY
}

enum NotificationType {
  INQUIRY_RECEIVED
  MEDIA_APPROVED
  MEDIA_REJECTED
  CAMPAIGN_UPDATE
  SYSTEM
}

enum ForumCategory {
  STRATEGY
  REGIONAL_INFO
}

enum ForumReportTarget {
  POST
  COMMENT
}

/** 관리자·분석용 사용자 활동 로그 분류 */
enum UserActivityCategory {
  AUTH
  NAV
  API
  SECURITY
  DATA
  SYSTEM
}

enum MediaReviewReportStatus {
  PENDING
  DISMISSED
  ACTIONED
}

model Media {
  id                String         @id @default(uuid()) @db.Uuid
  mediaName         String
  category          MediaCategory
  description       String?
  locationJson      Json           // { address?, district?, lat?, lng?, map_link? }
  price             Int?           // 단위: 원
  cpm               Int?           // CPM (원)
  exposureJson      Json?          // { daily_traffic?, monthly_impressions?, reach?, frequency? }
  targetAudience    String?
  images            String[]       // 이미지 URL 또는 설명
  /** 제안서 PDF Vision + 사용자 업로드 매체 사진 URL */
  sampleImages        String[]       @default([])
  /** 사용자 업로드 매체 사진별 Grok Vision 설명 (sampleImages와 대응) */
  sampleDescriptions  String[]       @default([])
  tags              String[]       // 매체·기능 키워드 (LED, 빌보드 등)
  audienceTags      String[]       @default([]) // 타겟 정규화 태그 (검색·필터용)
  pros              String?
  cons              String?
  trustScore        Int?           // 0–100
  viewCount         Int            @default(0)
  status            MediaStatus    @default(DRAFT)
  /** 업로드 직후 AI 심사 요약 (한국어) */
  aiReviewComment   String?
  aiReviewScore     Int?
  /** 추천 전용 점수(0-100), 없으면 런타임 휴리스틱으로 계산 */
  aiMatchScore      Int?
  /** 글로벌 추천용 국가 코드(ISO-3166-1 alpha-2) */
  globalCountryCode String?
  /** 가격 표기 통화 (기본 KRW) */
  currency          CurrencyCode @default(KRW)
  /** 노출 가능 기간 (매체사 등록) */
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  /** Per-day availability: [{ date: "2025-04-01", status: "available"|"booked"|"inquiry" }, …] */
  availabilityJson  Json?
  adminMemo         String?
  proposalFileUrl   String?        // S3/storage 원본 PDF 링크
  /** 재파싱 전 폼 스냅샷 히스토리 { backups: [...], lastReparseAt } */
  parseHistory      Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String?       @db.Uuid

  createdBy User? @relation("MediaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  inquiries   Inquiry[]
  caseStudies CaseStudy[]
  wishlists   Wishlist[]
  reviews     MediaReview[]
  recommendationDismissals RecommendationDismissal[]

  @@index([status, category])
  @@index([createdById])
}

model CaseStudy {
  id          String   @id @default(uuid()) @db.Uuid
  mediaId     String   @db.Uuid
  title       String
  description String?  @db.Text
  client      String?
  result      String?  @db.Text
  images      String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
}

model User {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  UserRole  @default(ADVERTISER)
  /** Legacy Clerk user id (optional; NextAuth users leave null) */
  clerkId               String?   @unique
  onboardingCompleted   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  proposals      MediaProposal[]  @relation("ProposalsByPartner")
  reviews        ReviewLog[]      @relation("ReviewsByReviewer")
  matches        Matching[]      @relation("MatchingsByBrand")
  mediaCreated   Media[]         @relation("MediaCreatedBy")
  campaignDrafts CampaignDraft[] @relation("CampaignDraftsByUser")
  campaigns      Campaign[]      @relation("CampaignsByUser")
  campaignInvoices CampaignInvoice[] @relation("CampaignInvoicesByUser")
  inquiriesSent  Inquiry[]      @relation("InquiryByAdvertiser")
  notifications  Notification[]
  wishlists      Wishlist[]
  mediaReviews   MediaReview[]  @relation("MediaReviewsByUser")
  recommendationDismissals RecommendationDismissal[]
  forumPosts     ForumPost[]    @relation("ForumPostsByAuthor")
  forumComments  ForumComment[] @relation("ForumCommentsByAuthor")
  forumReports   ForumReport[]  @relation("ForumReportsByReporter")
  mediaReviewReportsFiled   MediaReviewReport[] @relation("MediaReviewReportsByReporter")
  mediaReviewReportsResolved MediaReviewReport[] @relation("MediaReviewReportsResolvedBy")

  partnershipAppsSubmitted PartnershipApplication[] @relation("PartnershipAppSubmitter")
  partnershipAppsReviewed  PartnershipApplication[] @relation("PartnershipAppReviewer")
  partnershipContractsCreated PartnershipContract[] @relation("PartnershipContractCreator")

  partnerApiKeys       PartnerApiKey[]
  partnerMediaWebhook  PartnerMediaWebhook?

  autoBidRules AutoBidRule[]
  autoBidRuns  AutoBidRun[]

  twoFactorSecret       String?
  twoFactorEnabled      Boolean           @default(false)
  twoFactorBackupCodes  String?           @db.Text
  emailOtpEnabled       Boolean           @default(false)
  smsOtpEnabled         Boolean           @default(false)
  phoneE164             String?
  securityPhoneVerified Boolean           @default(false)
  /** RSA-OAEP (SPKI) base64 for inquiry E2E; media owner holds matching PKCS#8 offline. */
  inquiryE2ePublicKeySpki String?         @db.Text
  /** Per NotificationType: false = muted in-app; missing/true = on. */
  notificationCategoryPrefs Json?

  /** 친구 초대용 고유 코드 (대문자·숫자). 최초 조회 시 발급. */
  referralCode         String?   @unique
  /** 가입 시 추천인 User.id (1회만 설정) */
  referredById         String?   @db.Uuid
  /** 추천 리워드 누적 포인트(플랫폼 크레딧 등에 활용 가능) */
  referralCreditPoints Int       @default(0)

  referredBy User?  @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals  User[] @relation("UserReferrals")

  @@index([referredById])

  loginDevices          LoginDevice[]
  webAuthnCredentials   WebAuthnCredential[]
  activityLogs          UserActivityLog[]
}

model UserActivityLog {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String               @db.Uuid
  action    String
  category  UserActivityCategory
  meta      Json?
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([category, createdAt])
}

model LoginDevice {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  deviceKey  String
  nickname   String?
  userAgent  String?
  ipLast     String?
  lastSeenAt DateTime @updatedAt
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceKey])
  @@index([userId])
}

model WebAuthnCredential {
  credentialId        String   @id
  userId              String   @db.Uuid
  credentialPublicKey String   @db.Text
  counter             Int      @default(0)
  transports          String?
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// 미디어 믹스 기반 캠페인 초안·제출 (대시보드 연동 예정)
model Campaign {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @db.Uuid
  title            String?
  status           CampaignStatus @default(DRAFT)
  budget_krw       Int
  duration_weeks   Int
  target_summary   String         @db.Text
  location_summary String         @db.Text
  /** proposalId, media_ids, total_cost, estimated_reach, breakdown, reasoning_ko 등 */
  mediaMix         Json
  /** 옴니채널 카트로 생성한 캠페인 여부 */
  omniChannel      Boolean        @default(false)
  /** 옴니채널에 담긴 매체 UUID 목록 (빠른 필터·배지용, mediaMix와 동기) */
  omniMediaIds     Json?
  /** 파싱 스냅샷 (대시보드·재편집용) */
  parseSnapshot    Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation("CampaignsByUser", fields: [userId], references: [id], onDelete: Cascade)
  invoice CampaignInvoice?

  @@index([userId, status])
  @@index([userId, createdAt])
}

model CampaignInvoice {
  id                   String                @id @default(uuid()) @db.Uuid
  campaignId           String                @unique @db.Uuid
  userId               String                @db.Uuid
  amountKrw            Int
  /** 스냅샷: 캠페인 집행 종료 시각(createdAt + duration) */
  campaignEndAt        DateTime
  dueAt                DateTime
  status               CampaignInvoiceStatus @default(OPEN)
  /** 최초 인보이스 발행 메일 전송 시각 */
  initialEmailSentAt   DateTime?
  lastReminderAt       DateTime?
  reminderCount        Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation("CampaignInvoicesByUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, dueAt])
}

model CampaignDraft {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  name          String?
  campaignPeriod String?
  totalBudgetRaw String?
  totalBudgetKrw Int?
  channelDooh   Boolean  @default(true)
  channelWeb    Boolean  @default(false)
  channelMobile Boolean  @default(false)
  mediaIds      Json     // string[] of media UUIDs
  createdAt     DateTime @default(now())

  user User? @relation("CampaignDraftsByUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model CampaignEvent {
  id              String   @id @default(uuid()) @db.Uuid
  campaignDraftId String?  @db.Uuid
  occurredAt      DateTime @default(now())
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend          Int      @default(0)

  @@index([campaignDraftId, occurredAt])
}

model MediaProposal {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  title       String
  description String?
  keywords    Json?
  mediaTypes  Json?
  summary     String?
  tone        String?
  location    Json
  mediaType   MediaType
  size        String?
  priceMin    Int?
  priceMax    Int?
  images      String[]
  status      ProposalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User        @relation("ProposalsByPartner", fields: [userId], references: [id], onDelete: Cascade)
  reviews   ReviewLog[] @relation("ReviewsByProposal")
  matchings Matching[]

  @@index([status, userId])
}

model ReviewLog {
  id         String         @id @default(uuid()) @db.Uuid
  proposalId String         @db.Uuid
  reviewerId String?        @db.Uuid
  decision   ProposalStatus
  comment    String?
  aiScore    Float?
  createdAt  DateTime       @default(now())

  proposal MediaProposal @relation("ReviewsByProposal", fields: [proposalId], references: [id], onDelete: Cascade)
  reviewer User?         @relation("ReviewsByReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([proposalId])
  @@index([reviewerId])
  @@index([decision])
}

model Matching {
  id         String         @id @default(uuid()) @db.Uuid
  brandId    String         @db.Uuid
  proposalId String         @db.Uuid
  status     MatchingStatus @default(SAVED)
  desiredPeriod String?
  budget     Int?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  brand    User          @relation("MatchingsByBrand", fields: [brandId], references: [id], onDelete: Cascade)
  proposal MediaProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([status, brandId])
}

model Inquiry {
  id            String        @id @default(uuid()) @db.Uuid
  advertiserId  String        @db.Uuid
  mediaId       String        @db.Uuid
  message       String        @db.Text
  /** AES-GCM envelope (JSON); message field uses E2E placeholder when set. */
  sensitiveEnvelope String?   @db.Text
  e2eEncrypted      Boolean   @default(false)
  desiredPeriod String?
  budget        Int?          // KRW
  contactEmail  String?
  contactPhone  String?
  status        InquiryStatus @default(PENDING)
  adminMemo     String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  advertiser User  @relation("InquiryByAdvertiser", fields: [advertiserId], references: [id], onDelete: Cascade)
  media      Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  contract   InquiryContract?

  @@index([advertiserId])
  @@index([mediaId])
  @@index([status])
  @@index([advertiserId, createdAt])
  @@index([mediaId, createdAt])
}

model InquiryContract {
  id                    String                @id @default(uuid()) @db.Uuid
  inquiryId             String                @unique @db.Uuid
  /** 확정 예산(KRW); 문의 budget과 다를 수 있음 */
  agreedBudgetKrw       Int?
  agreedPeriod          String?
  status                InquiryContractStatus @default(DRAFT)
  advertiserSignName    String?
  advertiserSignedAt    DateTime?
  mediaOwnerSignName    String?
  mediaOwnerSignedAt    DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

enum AutoBidRuleStatus {
  ACTIVE
  PAUSED
}

/** 광고주 자동 문의(입찰) 규칙: 조건에 맞는 매체에 일괄 문의 생성 */
model AutoBidRule {
  id                  String            @id @default(uuid()) @db.Uuid
  userId              String            @db.Uuid
  name                String
  /** 매체 price(원) 상한 — null인 매체도 포함 */
  maxBudgetKrw        Int
  /** ISO-3166-1 alpha-2 코드 배열 JSON; 빈 배열이면 국가 제한 없음 */
  countryCodes        Json
  periodStart         DateTime
  periodEnd           DateTime
  status              AutoBidRuleStatus @default(PAUSED)
  messageTemplate     String            @db.Text
  maxInquiriesPerRun  Int               @default(5)
  /** 자동 실행·크론 시 최소 간격(시간). 수동 실행은 force로 우회 가능 */
  minHoursBetweenRuns Int               @default(6)
  lastRunAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs AutoBidRun[]

  @@index([userId, status])
  @@index([status, periodStart, periodEnd])
}

model AutoBidRun {
  id                String   @id @default(uuid()) @db.Uuid
  ruleId            String   @db.Uuid
  userId            String   @db.Uuid
  matchedCount      Int
  createdInquiryIds Json
  createdAt         DateTime @default(now())

  rule AutoBidRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
  @@index([userId, createdAt])
}

// --- Advanced keyword targeting for DOOH ---

model TagCategory {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  ko        String
  en        String
  ja        String?
  order     Int      @default(0)

  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id           String       @id @default(uuid()) @db.Uuid
  code         String       @unique
  ko           String
  en           String
  ja           String?
  categoryId   String       @db.Uuid
  category     TagCategory  @relation(fields: [categoryId], references: [id])
  aliases      String[]

  mappingField String       // e.g. "location.district"
  mappingType  String       // e.g. "equals", "in", "contains"
  mappingValue String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([categoryId])
}

model SavedFilterPreset {
  id        String   @id @default(uuid()) @db.Uuid
  nameKo    String
  nameEn    String
  filterJson Json
  ownerId   String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  rating    Int
  message   String?  @db.Text
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  read      Boolean          @default(false)
  starred   Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, starred])
}

model News {
  id         String    @id @default(uuid()) @db.Uuid
  slug       String?   @unique
  title      String
  excerpt    String?
  content    String?   @db.Text
  link       String?   @unique
  pubDate    DateTime?
  category   String    @default("Industry News")
  coverImage String?
  imageUrl   String?
  source     String?
  locale     String    @default("en")
  published  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([locale, published, createdAt])
  @@index([category])
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  mediaId   String   @db.Uuid
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId, createdAt])
}

/// 맞춤 추천에서 숨김·부정 피드백 (로그인 사용자만 DB 저장)
model RecommendationDismissal {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  mediaId   String   @db.Uuid
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId, createdAt])
}

model MediaReview {
  id        String   @id @default(uuid()) @db.Uuid
  mediaId   String   @db.Uuid
  userId    String   @db.Uuid
  rating    Int
  content   String?  @db.Text
  images    String[] @default([])
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User  @relation("MediaReviewsByUser", fields: [userId], references: [id], onDelete: Cascade)
  abuseReports MediaReviewReport[]

  @@unique([mediaId, userId])
  @@index([mediaId, createdAt])
  @@index([userId])
}

model MediaReviewReport {
  id           String                  @id @default(uuid()) @db.Uuid
  reviewId     String                  @db.Uuid
  reporterId   String                  @db.Uuid
  reason       String?                 @db.Text
  status       MediaReviewReportStatus @default(PENDING)
  createdAt    DateTime                @default(now())
  resolvedAt   DateTime?
  resolvedById String?                 @db.Uuid

  review     MediaReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter   User        @relation("MediaReviewReportsByReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User?       @relation("MediaReviewReportsResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([reviewId, reporterId])
  @@index([status, createdAt])
  @@index([reviewId])
}

model ForumPost {
  id        String        @id @default(uuid()) @db.Uuid
  authorId  String        @db.Uuid
  category  ForumCategory
  title     String
  body      String        @db.Text
  viewCount Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  author   User            @relation("ForumPostsByAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments ForumComment[]
  reports  ForumReport[]

  @@index([category, createdAt])
  @@index([authorId, createdAt])
  @@index([createdAt])
}

model ForumComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  authorId  String   @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now())

  post    ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation("ForumCommentsByAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reports ForumReport[]

  @@index([postId, createdAt])
  @@index([authorId])
}

model ForumReport {
  id         String            @id @default(uuid()) @db.Uuid
  targetType ForumReportTarget
  postId     String?           @db.Uuid
  commentId  String?           @db.Uuid
  reporterId String            @db.Uuid
  reason     String?           @db.Text
  createdAt  DateTime          @default(now())

  reporter User          @relation("ForumReportsByReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post     ForumPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment  ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([commentId])
  @@index([reporterId, createdAt])
}

enum PartnershipType {
  MEDIA_NETWORK
  AGENCY
  TECH_PLATFORM
  BRAND
  OTHER
}

enum PartnershipApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PartnershipContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model PartnershipApplication {
  id              String                       @id @default(uuid()) @db.Uuid
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  companyName     String
  contactName     String
  email           String
  phone           String?
  website         String?
  type            PartnershipType
  message         String                       @db.Text
  submitterUserId String?                      @db.Uuid
  status          PartnershipApplicationStatus @default(PENDING)
  adminMemo       String?                      @db.Text
  reviewedAt      DateTime?
  reviewedById    String?                      @db.Uuid

  submitterUser User?                 @relation("PartnershipAppSubmitter", fields: [submitterUserId], references: [id], onDelete: SetNull)
  reviewedBy    User?                 @relation("PartnershipAppReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  contracts     PartnershipContract[]

  @@index([status, createdAt])
  @@index([email])
}

model PartnershipContract {
  id            String                    @id @default(uuid()) @db.Uuid
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  applicationId String?                   @db.Uuid
  title         String
  summary       String?                   @db.Text
  documentUrl   String?
  effectiveDate DateTime?
  endDate       DateTime?
  status        PartnershipContractStatus @default(DRAFT)
  createdById   String?                   @db.Uuid

  application PartnershipApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  createdBy   User?                   @relation("PartnershipContractCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([applicationId])
  @@index([status, createdAt])
}

/** 매체사 파트너 REST API 키 (시크릿은 SHA-256 해시만 저장) */
model PartnerApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  name       String
  keyPrefix  String
  keyHash    String    @unique
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  lastUsedAt DateTime?

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages PartnerApiUsage[]

  @@index([userId])
}

model PartnerApiUsage {
  id        String   @id @default(uuid()) @db.Uuid
  keyId     String   @db.Uuid
  path      String
  method    String
  status    Int
  createdAt DateTime @default(now())

  key PartnerApiKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId, createdAt])
}

/** 매체 변경 시 POST 콜백 (HTTPS URL) */
model PartnerMediaWebhook {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  url       String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AbExperimentStatus {
  DRAFT
  RUNNING
  STOPPED
  CONCLUDED
}

enum AbVariantKey {
  A
  B
}

enum AbEventType {
  IMPRESSION
  CONVERSION
}

model AbExperiment {
  id                 String             @id @default(uuid()) @db.Uuid
  slug               String             @unique
  name               String
  status             AbExperimentStatus @default(DRAFT)
  /** 0–100: 해당 비율만큼 변형 A, 나머지 B */
  trafficSplitA      Int                @default(50)
  winnerVariant      AbVariantKey?
  /** 자동 승자 판정 시 변형별 최소 노출 수 */
  minImpressionsAuto Int                @default(100)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  events             AbEvent[]
}

model AbEvent {
  id           String       @id @default(uuid()) @db.Uuid
  experimentId String       @db.Uuid
  variant      AbVariantKey
  type         AbEventType
  subjectKey   String
  createdAt    DateTime     @default(now())

  experiment AbExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, variant, type])
  @@index([experimentId, createdAt])
}

