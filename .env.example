# Copy to .env.local and fill values: cp .env.example .env.local

# Database
DATABASE_URL=

# Supabase (Storage uploads — see lib/storage/supabase-upload.ts)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Cursor MCP (PAT + project scope) — do NOT commit real tokens.
# https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=
# Project ref from dashboard URL: https://supabase.com/dashboard/project/<project_ref>
# SUPABASE_PROJECT_REF=

# NextAuth 기본 설정 (필수!)
NEXTAUTH_URL=http://localhost:3000
# 시크릿: openssl rand -base64 32
NEXTAUTH_SECRET=여기에_랜덤_시크릿_넣기

# Google 로그인 옵션 (나중에 쓰고 싶으면 Google Cloud Console에서 OAuth 클라이언트 ID/시크릿 발급)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin 부트스트랩용 (특정 이메일로 가입하면 자동 ADMIN 역할 부여) — 본인 이메일로 .env.local에서 수정
NEXTAUTH_ADMIN_EMAILS=jaehan@example.com,admin@xthex.com

# Legacy Clerk webhook (optional — only if you still sync Clerk → DB)
# CLERK_WEBHOOK_SECRET=

# Map (explore)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Partner upload
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Seoul living population (일 유동인구 제안) - data.seoul.go.kr 인증키
SEOUL_DATA_API_KEY=여기에키붙여넣기
