# ─── XtheX Production Environment ───────────────────────────────
# These values are set via Vercel Environment Variables UI.
# This file serves as a reference; actual secrets MUST NOT be committed.

# Database (Neon pooled connection)
DATABASE_URL=

# NextAuth
NEXTAUTH_URL=https://xthex.com
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=https://xthex.com

# Admin bootstrap
NEXTAUTH_ADMIN_EMAILS=

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cloudinary (media uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Supabase (storage)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# AI providers
# OPENAI_API_KEY=
# GROK_API_KEY=

# Seoul living population API
# SEOUL_DATA_API_KEY=

# Error tracking (Sentry)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Resend (email)
# RESEND_API_KEY=
