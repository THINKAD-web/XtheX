# Copy to .env.local and fill values: cp .env.example .env.local

# Database (Vercel / Neon: paste connection string in project Settings → Environment Variables)
DATABASE_URL=
# Local sync (dev): npx prisma migrate deploy   or   npx prisma db push
# Vercel production: prefer migrations — add to Build Command, e.g.
#   prisma migrate deploy && next build
# (or run once: npx prisma migrate deploy with DATABASE_URL in the shell)
# db push is for prototyping; production should use committed migrations in prisma/migrations/

# Supabase (Storage uploads — see lib/storage/supabase-upload.ts)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Cursor MCP (PAT + project scope) — do NOT commit real tokens.
# https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=
# Project ref from dashboard URL: https://supabase.com/dashboard/project/<project_ref>
# SUPABASE_PROJECT_REF=

# NextAuth 기본 설정 (필수!)
# ⚠️ 브라우저에서 접속하는 주소·포트와 반드시 일치 (예: dev가 3003이면 http://localhost:3003)
# 불일치 시 next-auth 세션 fetch가 HTML을 받아 CLIENT_FETCH_ERROR(Unexpected token '<') 발생 가능.
# localhost 와 127.0.0.1 은 다른 오리진이므로 한쪽으로 통일 (세션/쿠키 불일치 방지).
NEXTAUTH_URL=http://localhost:3000
# 시크릿: openssl rand -base64 32
NEXTAUTH_SECRET=여기에_랜덤_시크릿_넣기
# Production canonical URL (metadata/links/SEO)
# NEXT_PUBLIC_APP_URL=https://xthex.com

# Google 로그인 옵션 (나중에 쓰고 싶으면 Google Cloud Console에서 OAuth 클라이언트 ID/시크릿 발급)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin 부트스트랩용 (특정 이메일로 가입하면 자동 ADMIN 역할 부여) — 본인 이메일로 .env.local에서 수정
NEXTAUTH_ADMIN_EMAILS=jaehan@example.com,admin@xthex.com

# Optional: second lock for /admin/* after NextAuth (HttpOnly cookie, 7 days). Leave unset to disable.
# ADMIN_SITE_PASSWORD=
# Optional separate HMAC secret for that cookie (defaults to NEXTAUTH_SECRET)
# ADMIN_GATE_SECRET=

# Resend: 문의 접수 시 관리자 알림 (쉼표로 여러 주소)
# ADMIN_INQUIRY_NOTIFY_EMAIL=ops@xthex.com,admin@xthex.com

# Resend (고객 접수 확인 + 관리자 알림)
# RESEND_API_KEY=
# RESEND_FROM=XtheX <onboarding@resend.dev>

# --- Third-party integrations (Vercel: add same keys per environment) ---
#
# Auth: this repo uses NextAuth (credentials + optional Google OAuth above).
# Clerk SDK is not wired in app/layout — keys below are for webhook sync only unless you add @clerk/nextjs.
# Clerk Dashboard → API Keys: https://dashboard.clerk.com/
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...
# Webhook signing secret (Clerk → /api/webhooks/clerk)
# CLERK_WEBHOOK_SECRET=whsec_...

# Map (explore — browser Maps JS + optional server geocoding fallback)
# Google Cloud Console → APIs: Maps JavaScript API, Places (if used); restrict key by HTTP referrer (prod domain + localhost).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional server-only Geocoding API key (restrict by IP on Google Cloud); falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# GOOGLE_MAPS_GEOCODING_KEY=

# Cloudinary (partner / media image upload — unsigned preset for widget or signed server uploads)
# Dashboard → Settings: https://console.cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Stripe — inquiry contract checkout: POST /api/inquiry/[id]/checkout → redirect; webhook /api/webhooks/stripe
# Dashboard → Developers → API keys: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Stripe CLI or Dashboard → webhook → signing secret
# NEXT_PUBLIC_APP_URL must match production domain (success/cancel URLs).
# Dev: mock pay still available in Payment modal (NODE_ENV=development only).

# Seoul living population (일 유동인구 제안) - data.seoul.go.kr 인증키
SEOUL_DATA_API_KEY=여기에키붙여넣기

# AI providers (optional, feature-dependent)
# GROK_API_KEY=xai-...
# XAI_API_KEY=xai-...
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
