-- Idempotent seed for local development (PostgreSQL).

-- Users (upsert by unique clerkId)
INSERT INTO "User" ("id", "clerkId", "role", "email", "name", "createdAt")
VALUES
  ('11111111-1111-1111-1111-111111111111', 'test_partner1', 'PARTNER', 'partner1@xthex.test', 'Test Partner 1', now()),
  ('22222222-2222-2222-2222-222222222222', 'test_partner2', 'PARTNER', 'partner2@xthex.test', 'Test Partner 2', now()),
  ('33333333-3333-3333-3333-333333333333', 'test_admin',    'ADMIN',   'admin@xthex.test',    'Test Admin',    now())
ON CONFLICT ("clerkId") DO UPDATE SET
  "role" = EXCLUDED."role",
  "email" = EXCLUDED."email",
  "name" = EXCLUDED."name";

