# XtheX environment variables — copy to .env.local and fill values:
#   cp .env.example .env.local
#
# Key conventions: this repo uses NextAuth v4 (`NEXTAUTH_*`, `GOOGLE_CLIENT_*`).
# Auth.js v5 (`AUTH_*`) is NOT used. See DEPLOYMENT.md for the migration map
# if you ever upgrade.
#
# In Vercel, set the same keys under Settings → Environment Variables for
# Production / Preview / Development separately. Never share a Production DB
# with Preview deployments.

# ─── Phase 1 (current) — REQUIRED in production ──────────────────────────

# PostgreSQL connection string (Neon pooled URL is fine).
# Vercel: Settings → Environment Variables.
# Local sync (dev): npx prisma migrate deploy   or   npx prisma db push
# Production: committed migrations under prisma/migrations/ via vercel-build.
DATABASE_URL=

# NextAuth canonical URL.
# ⚠️ MUST match the host:port the browser actually uses (dev=3000? 3003?).
# A mismatch makes session fetches receive HTML and triggers
# CLIENT_FETCH_ERROR (Unexpected token '<'). Pick one of localhost or
# 127.0.0.1 and stick with it (different origins → different cookies).
NEXTAUTH_URL=http://localhost:3000

# JWT signing key. Generate: openssl rand -base64 32
# Without this, getToken() returns null and EVERY admin/protected route
# rejects with 401/redirect. The single most common Vercel misconfig.
NEXTAUTH_SECRET=여기에_랜덤_시크릿_넣기

# Canonical production URL — used for metadataBase, OG images, Stripe
# success/cancel URLs, sitemaps. Must match the deployed domain.
# NEXT_PUBLIC_APP_URL=https://xthex.com

# Bootstrap admin emails (comma-separated). On first sign-in, a matching
# email is auto-promoted to ADMIN. Edit per environment.
NEXTAUTH_ADMIN_EMAILS=jaehan@example.com,admin@xthex.com

# ─── Phase 1 — Optional admin hardening ──────────────────────────────────

# Second-factor lock on /admin/* AFTER NextAuth (HttpOnly cookie, 7 days).
# Leave unset to disable. Pair with ADMIN_GATE_SECRET below if you want a
# separate signing key (defaults to NEXTAUTH_SECRET).
# ADMIN_SITE_PASSWORD=
# ADMIN_GATE_SECRET=

# ─── Phase 1 — OAuth (optional) ──────────────────────────────────────────

# Google Sign-In. Create OAuth client at https://console.cloud.google.com/
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
# (NextAuth v4 keys — NOT AUTH_GOOGLE_ID/SECRET.)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Phase 2 — Maps & uploads ────────────────────────────────────────────

# Google Maps JavaScript API. Public (browser) — restrict by HTTP referrer
# in Google Cloud Console (prod domain + localhost only).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional server-only Geocoding key (restrict by IP). Falls back to the
# public key above if unset.
# GOOGLE_MAPS_GEOCODING_KEY=

# Cloudinary unsigned upload preset for partner/media images.
# Restrict the preset to a single folder + allowed formats in the dashboard.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Supabase Storage (alternative to Cloudinary — see lib/storage/supabase-upload.ts).
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Cursor MCP scope (PAT, project ref) — never commit real values.
# Personal access token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# ─── Phase 4 — Payments ──────────────────────────────────────────────────

# Stripe checkout for inquiry contracts.
# Endpoints: POST /api/inquiry/[id]/checkout · webhook /api/webhooks/stripe
# Get keys: https://dashboard.stripe.com/apikeys
# NEXT_PUBLIC_APP_URL must equal production domain (success/cancel URLs).
# Dev: mock pay is available in the Payment modal when NODE_ENV=development.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Phase 5 — Email ─────────────────────────────────────────────────────

# Resend — customer confirmations + admin notifications.
# RESEND_API_KEY=
# RESEND_FROM=XtheX <onboarding@resend.dev>
# ADMIN_INQUIRY_NOTIFY_EMAIL=ops@xthex.com,admin@xthex.com

# ─── Phase 6 — AI providers ──────────────────────────────────────────────
#
# Currently FOUR providers are wired (xAI/Grok, Groq, OpenAI, Anthropic).
# Different features pick different providers — see lib/ai/*. Planned for
# v1.1: consolidate to Anthropic only.
#
# - ANTHROPIC_API_KEY — admin proposal review (lib/ai/reviewProposal.ts)
# - XAI_API_KEY / GROK_API_KEY — natural-language mix-media search,
#     media photo descriptions, structured proposal parsing
# - GROQ_API_KEY — fallback completions
# - OPENAI_API_KEY — last-resort completions and vision fallback
#
# All optional individually; if a feature's preferred provider is unset,
# the helper falls through to the next in priority order.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# XAI_API_KEY=xai-...
# GROK_API_KEY=xai-...
# XAI_MODEL=
# GROK_MODEL=
# XAI_VISION_MODEL=grok-4
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# ─── External data ───────────────────────────────────────────────────────

# Seoul living population (data.seoul.go.kr) — daily footfall suggestions.
SEOUL_DATA_API_KEY=여기에키붙여넣기

# ─── Clerk (NOT USED — webhook compatibility only) ───────────────────────
#
# This repo uses NextAuth, not Clerk. The keys below are wired only for
# /api/webhooks/clerk. To actually enable Clerk auth you would need to
# install @clerk/nextjs, swap providers, and migrate sessions — that is a
# Phase-3+ decision; do not set these unless you've made that decision.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
