generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADVERTISER
  MEDIA_OWNER
  ADMIN
}

enum MediaType {
  BILLBOARD
  DIGITAL
  TRANSIT
  OTHER
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
  ANALYZING
  ANALYZED
  FAILED
}

enum MatchingStatus {
  SAVED
  INQUIRY
  NEGOTIATION
  CONTRACTING
  ACTIVE
  COMPLETED
  CANCELLED
}

// --- THINKKAD-style OOH Media (AI 업로드 → 검토 → 상세페이지) ---
enum MediaCategory {
  BILLBOARD
  DIGITAL_BOARD
  TRANSIT
  STREET_FURNITURE
  WALL
  ETC
}

enum MediaStatus {
  DRAFT
  /** 매체사 업로드 후 AI/관리자 검토 대기 */
  PENDING
  PUBLISHED
  /** 관리자 거부 */
  REJECTED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum InquiryStatus {
  PENDING
  REPLIED
  CLOSED
}

enum CurrencyCode {
  KRW
  USD
  EUR
  JPY
}

enum NotificationType {
  INQUIRY_RECEIVED
  MEDIA_APPROVED
  MEDIA_REJECTED
  CAMPAIGN_UPDATE
  SYSTEM
}

model Media {
  id                String         @id @default(uuid()) @db.Uuid
  mediaName         String
  category          MediaCategory
  description       String?
  locationJson      Json           // { address?, district?, lat?, lng?, map_link? }
  price             Int?           // 단위: 원
  cpm               Int?           // CPM (원)
  exposureJson      Json?          // { daily_traffic?, monthly_impressions?, reach?, frequency? }
  targetAudience    String?
  images            String[]       // 이미지 URL 또는 설명
  /** 제안서 PDF Vision + 사용자 업로드 매체 사진 URL */
  sampleImages        String[]       @default([])
  /** 사용자 업로드 매체 사진별 Grok Vision 설명 (sampleImages와 대응) */
  sampleDescriptions  String[]       @default([])
  tags              String[]       // 매체·기능 키워드 (LED, 빌보드 등)
  audienceTags      String[]       @default([]) // 타겟 정규화 태그 (검색·필터용)
  pros              String?
  cons              String?
  trustScore        Int?           // 0–100
  viewCount         Int            @default(0)
  status            MediaStatus    @default(DRAFT)
  /** 업로드 직후 AI 심사 요약 (한국어) */
  aiReviewComment   String?
  aiReviewScore     Int?
  /** 추천 전용 점수(0-100), 없으면 런타임 휴리스틱으로 계산 */
  aiMatchScore      Int?
  /** 글로벌 추천용 국가 코드(ISO-3166-1 alpha-2) */
  globalCountryCode String?
  /** 가격 표기 통화 (기본 KRW) */
  currency          CurrencyCode @default(KRW)
  /** 노출 가능 기간 (매체사 등록) */
  availabilityStart DateTime?
  availabilityEnd   DateTime?
  /** Per-day availability: [{ date: "2025-04-01", status: "available"|"booked"|"inquiry" }, …] */
  availabilityJson  Json?
  adminMemo         String?
  proposalFileUrl   String?        // S3/storage 원본 PDF 링크
  /** 재파싱 전 폼 스냅샷 히스토리 { backups: [...], lastReparseAt } */
  parseHistory      Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String?       @db.Uuid

  createdBy User? @relation("MediaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  inquiries   Inquiry[]
  caseStudies CaseStudy[]
  wishlists   Wishlist[]
  reviews     MediaReview[]
  recommendationDismissals RecommendationDismissal[]

  @@index([status, category])
  @@index([createdById])
}

model CaseStudy {
  id          String   @id @default(uuid()) @db.Uuid
  mediaId     String   @db.Uuid
  title       String
  description String?  @db.Text
  client      String?
  result      String?  @db.Text
  images      String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
}

model User {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  UserRole  @default(ADVERTISER)
  /** Legacy Clerk user id (optional; NextAuth users leave null) */
  clerkId               String?   @unique
  onboardingCompleted   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  proposals      MediaProposal[]  @relation("ProposalsByPartner")
  reviews        ReviewLog[]      @relation("ReviewsByReviewer")
  matches        Matching[]      @relation("MatchingsByBrand")
  mediaCreated   Media[]         @relation("MediaCreatedBy")
  campaignDrafts CampaignDraft[] @relation("CampaignDraftsByUser")
  campaigns      Campaign[]      @relation("CampaignsByUser")
  inquiriesSent  Inquiry[]      @relation("InquiryByAdvertiser")
  notifications  Notification[]
  wishlists      Wishlist[]
  mediaReviews   MediaReview[]  @relation("MediaReviewsByUser")
  recommendationDismissals RecommendationDismissal[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// 미디어 믹스 기반 캠페인 초안·제출 (대시보드 연동 예정)
model Campaign {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @db.Uuid
  title            String?
  status           CampaignStatus @default(DRAFT)
  budget_krw       Int
  duration_weeks   Int
  target_summary   String         @db.Text
  location_summary String         @db.Text
  /** proposalId, media_ids, total_cost, estimated_reach, breakdown, reasoning_ko 등 */
  mediaMix         Json
  /** 옴니채널 카트로 생성한 캠페인 여부 */
  omniChannel      Boolean        @default(false)
  /** 옴니채널에 담긴 매체 UUID 목록 (빠른 필터·배지용, mediaMix와 동기) */
  omniMediaIds     Json?
  /** 파싱 스냅샷 (대시보드·재편집용) */
  parseSnapshot    Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user User @relation("CampaignsByUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
}

model CampaignDraft {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  name          String?
  campaignPeriod String?
  totalBudgetRaw String?
  totalBudgetKrw Int?
  channelDooh   Boolean  @default(true)
  channelWeb    Boolean  @default(false)
  channelMobile Boolean  @default(false)
  mediaIds      Json     // string[] of media UUIDs
  createdAt     DateTime @default(now())

  user User? @relation("CampaignDraftsByUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model CampaignEvent {
  id              String   @id @default(uuid()) @db.Uuid
  campaignDraftId String?  @db.Uuid
  occurredAt      DateTime @default(now())
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend          Int      @default(0)

  @@index([campaignDraftId, occurredAt])
}

model MediaProposal {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  title       String
  description String?
  keywords    Json?
  mediaTypes  Json?
  summary     String?
  tone        String?
  location    Json
  mediaType   MediaType
  size        String?
  priceMin    Int?
  priceMax    Int?
  images      String[]
  status      ProposalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User        @relation("ProposalsByPartner", fields: [userId], references: [id], onDelete: Cascade)
  reviews   ReviewLog[] @relation("ReviewsByProposal")
  matchings Matching[]

  @@index([status, userId])
}

model ReviewLog {
  id         String         @id @default(uuid()) @db.Uuid
  proposalId String         @db.Uuid
  reviewerId String?        @db.Uuid
  decision   ProposalStatus
  comment    String?
  aiScore    Float?
  createdAt  DateTime       @default(now())

  proposal MediaProposal @relation("ReviewsByProposal", fields: [proposalId], references: [id], onDelete: Cascade)
  reviewer User?         @relation("ReviewsByReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([proposalId])
  @@index([reviewerId])
  @@index([decision])
}

model Matching {
  id         String         @id @default(uuid()) @db.Uuid
  brandId    String         @db.Uuid
  proposalId String         @db.Uuid
  status     MatchingStatus @default(SAVED)
  desiredPeriod String?
  budget     Int?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  brand    User          @relation("MatchingsByBrand", fields: [brandId], references: [id], onDelete: Cascade)
  proposal MediaProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([status, brandId])
}

model Inquiry {
  id            String        @id @default(uuid()) @db.Uuid
  advertiserId  String        @db.Uuid
  mediaId       String        @db.Uuid
  message       String        @db.Text
  desiredPeriod String?
  budget        Int?          // KRW
  contactEmail  String?
  contactPhone  String?
  status        InquiryStatus @default(PENDING)
  adminMemo     String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  advertiser User  @relation("InquiryByAdvertiser", fields: [advertiserId], references: [id], onDelete: Cascade)
  media      Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([advertiserId])
  @@index([mediaId])
  @@index([status])
  @@index([advertiserId, createdAt])
  @@index([mediaId, createdAt])
}

// --- Advanced keyword targeting for DOOH ---

model TagCategory {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  ko        String
  en        String
  ja        String?
  order     Int      @default(0)

  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id           String       @id @default(uuid()) @db.Uuid
  code         String       @unique
  ko           String
  en           String
  ja           String?
  categoryId   String       @db.Uuid
  category     TagCategory  @relation(fields: [categoryId], references: [id])
  aliases      String[]

  mappingField String       // e.g. "location.district"
  mappingType  String       // e.g. "equals", "in", "contains"
  mappingValue String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([categoryId])
}

model SavedFilterPreset {
  id        String   @id @default(uuid()) @db.Uuid
  nameKo    String
  nameEn    String
  filterJson Json
  ownerId   String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  rating    Int
  message   String?  @db.Text
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model News {
  id         String    @id @default(uuid()) @db.Uuid
  slug       String?   @unique
  title      String
  excerpt    String?
  content    String?   @db.Text
  link       String?   @unique
  pubDate    DateTime?
  category   String    @default("Industry News")
  coverImage String?
  imageUrl   String?
  source     String?
  locale     String    @default("en")
  published  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([locale, published, createdAt])
  @@index([category])
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  mediaId   String   @db.Uuid
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId, createdAt])
}

/// 맞춤 추천에서 숨김·부정 피드백 (로그인 사용자만 DB 저장)
model RecommendationDismissal {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  mediaId   String   @db.Uuid
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId, createdAt])
}

model MediaReview {
  id        String   @id @default(uuid()) @db.Uuid
  mediaId   String   @db.Uuid
  userId    String   @db.Uuid
  rating    Int
  content   String?  @db.Text
  images    String[] @default([])
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User  @relation("MediaReviewsByUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaId, userId])
  @@index([mediaId, createdAt])
  @@index([userId])
}

