-- Seed review logs: make idempotent by deleting matching rows then inserting
DELETE FROM "ReviewLog"
WHERE "reviewerId" = '33333333-3333-3333-3333-333333333333'
  AND "comment" = 'Seed: approved by admin';

INSERT INTO "ReviewLog" ("id", "proposalId", "reviewerId", "decision", "comment", "aiScore", "createdAt")
VALUES
  (
    'ffffffff-ffff-ffff-ffff-ffffffffffff',
    'bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb',
    '33333333-3333-3333-3333-333333333333',
    'APPROVED',
    'Seed: approved by admin',
    90,
    now()
  ),
  (
    '99999999-9999-9999-9999-999999999999',
    'dddddddd-dddd-dddd-dddd-dddddddddddd',
    '33333333-3333-3333-3333-333333333333',
